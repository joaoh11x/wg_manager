# Banco de Dados
# Preferência do projeto: DATABASE_URL (SQLAlchemy).
# Exemplo (local):
# DATABASE_URL=postgresql+psycopg://wireguard:wireguard@localhost:5432/wireguard_manager
# Exemplo (docker-compose: o host do Postgres dentro da rede é "postgres"):
# DATABASE_URL=postgresql+psycopg://wireguard:wireguard@postgres:5432/wireguard_manager
DATABASE_URL=postgresql+psycopg://wireguard:wireguard@localhost:5432/wireguard_manager

# Schema do Postgres onde as tabelas serão criadas (via search_path)
DB_SCHEMA=wireguard_manager

# (Opcional) Se estiver usando docker-compose e preferir controlar usuário/senha/db via env:
# POSTGRES_DB=wireguard_manager
# POSTGRES_USER=wireguard
# POSTGRES_PASSWORD=wireguard

# (Compatibilidade/legado) Evite usar. O app ainda aceita, mas o padrão é DATABASE_URL.
# SQLALCHEMY_DATABASE_URI=
# DATABASE_URI=

# Configurações do MikroTik
MIKROTIK_HOST=192.168.1.99
MIKROTIK_USER=your_mikrotik_username
MIKROTIK_PASS=your_mikrotik_password

# Autenticação JWT
JWT_SECRET_KEY=your_jwt_secret_key
JWT_ACCESS_TOKEN_EXPIRES=2629800  # tempo em segundos (exemplo: 1 mês)
ADMIN_PASSWORD=your_secure_admin_password